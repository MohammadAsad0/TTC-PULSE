# Create .gitignore first
cat > .gitignore << 'EOF'
# Virtual environment
.venv-ttc/
.venv/
.env

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# macOS
.DS_Store

# Data files (large binaries - optional, discuss with team)
# *.parquet
# *.duckdb
# *.pb

# Logs (optional)
# logs/
EOF

# Large data files
*.duckdb
*.csv
